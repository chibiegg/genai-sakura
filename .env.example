# さくらのAI Engine（必須）
SAKURA_AI_ENGINE_BASE_URL=https://api.ai.sakura.ad.jp/v1
SAKURA_AI_ENGINE_TOKEN=your-sakura-ai-engine-api-key

# Brave Search API（任意。法令調査AI lawsy の Web 検索で使用。
# 未設定の場合、lawsy は Web 検索なし（条文 DB のみ）で動作する）
BRAVE_SEARCH_API_KEY=

# GitHub ログイン（任意。Keycloak の Identity Brokering 経由）
# GitHub OAuth App の callback は {Keycloak}/realms/genai/broker/github/endpoint
# 登録は scripts/setup-github-idp.sh を実行
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 設定するとログインが GitHub 認可画面へ直行する
OIDC_IDP_HINT=

# ブランディング（任意。未設定なら「ここにロゴが入る」等のプレースホルダのまま）
# サービス名称（ブラウザタブのタイトル等）
SITE_TITLE=
# ヘッダー・フッターのロゴテキスト
SITE_LOGO_TEXT=
# ロゴ画像を使う場合の URL。.local/branding/ に置いたファイルは /branding/ で配信される
# 例: SITE_LOGO_IMAGE_URL=/branding/logo.svg
SITE_LOGO_IMAGE_URL=
# フッターのコピーライト表記
SITE_COPYRIGHT_TEXT=

# 安定ユーザーID 生成用の HMAC シークレット（本番では必ず変更する）
USER_IDENTIFIER_HMAC_SECRET=local-dev-secret-change-me
